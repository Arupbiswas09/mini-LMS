# ─── Required ───────────────────────────────────────────────────────────────
# Base URL for the freeapi.app backend.
# Default value is used automatically if this is absent.
EXPO_PUBLIC_API_BASE_URL=https://api.freeapi.app

# ─── Error Tracking (optional) ───────────────────────────────────────────────
# Sentry DSN – leave blank to disable Sentry (app works without it).
EXPO_PUBLIC_SENTRY_DSN=

# ─── Analytics / AI (optional) ───────────────────────────────────────────────
# Supabase project URL and anon key for analytics event logging.
# Leave blank to disable Supabase analytics.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Name of the Supabase Edge Function used for AI course recommendations.
# Default: ai-recommend
EXPO_PUBLIC_SUPABASE_AI_FUNCTION=ai-recommend
